{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IIS3DWB 설정 툴",
  "version": "1.0.0",
  "identifier": "com.shinho.iis3dwb.configtool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "IIS3DWB 진동센서 WiFi 설정",
        "width": 560,
        "height": 720,
        "resizable": false,
        "center": true,
        "minWidth": 560,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
